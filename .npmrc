auto-install-peers=true
strict-peer-dependencies=false
# Flat node_modules. Required so Prisma's generated client (`.prisma/client`)
# and `@prisma/client` resolve to the same place — pnpm's isolated store
# otherwise leaves `@prisma/client` re-exporting a stub instead of the
# generated types (breaks `JobStatus`/`ProviderKind`/… imports on Vercel).
node-linker=hoisted
