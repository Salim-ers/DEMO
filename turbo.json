{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL", "DIRECT_URL", "REDIS_URL", "APP_URL",
    "SUPABASE_URL", "SUPABASE_ANON_KEY", "SUPABASE_SERVICE_ROLE_KEY",
    "NEXTAUTH_SECRET", "NEXTAUTH_URL",
    "S3_ENDPOINT", "S3_REGION", "S3_BUCKET", "S3_ACCESS_KEY_ID", "S3_SECRET_ACCESS_KEY", "S3_FORCE_PATH_STYLE",
    "LLM_PROVIDER", "ANTHROPIC_API_KEY", "OPENAI_API_KEY",
    "HIGGSFIELD_API_KEY", "HIGGSFIELD_API_BASE_URL",
    "TTS_PROVIDER", "ELEVENLABS_API_KEY",
    "LOCAL_SECRET_ENCRYPTION_KEY",
    "PLAYWRIGHT_HEADLESS", "CAPTURE_DEFAULT_WIDTH", "CAPTURE_DEFAULT_HEIGHT",
    "RENDER_FPS", "RENDER_WIDTH", "RENDER_HEIGHT"
  ],
  "tasks": {
    "build": { "dependsOn": ["^build"], "outputs": ["dist/**", ".next/**", "!.next/cache/**"] },
    "dev": { "cache": false, "persistent": true },
    "lint": {},
    "typecheck": { "dependsOn": ["^build"] },
    "test": { "dependsOn": ["^build"] },
    "clean": { "cache": false }
  }
}
