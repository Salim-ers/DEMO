{
  "name": "demoforge",
  "private": true,
  "version": "0.1.0",
  "description": "DemoForge — generate premium SaaS demo videos from a real browser capture pipeline.",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --filter=@demoforge/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "worker": "pnpm --filter @demoforge/worker dev",
    "db:generate": "pnpm --filter @demoforge/db generate",
    "db:push": "pnpm --filter @demoforge/db push",
    "db:seed": "pnpm --filter @demoforge/db seed",
    "db:studio": "pnpm --filter @demoforge/db studio",
    "render:example": "pnpm --filter @demoforge/render render:example",
    "capture:install": "pnpm --filter @demoforge/capture exec playwright install chromium",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "prettier": "^3.3.3",
    "@types/node": "^22.5.5"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  }
}
