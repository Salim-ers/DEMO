{
  "name": "@demoforge/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./queue": "./src/queue.ts",
    "./queue.js": "./src/queue.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "enqueue": "tsx src/enqueue.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@demoforge/shared": "workspace:*",
    "@demoforge/db": "workspace:*",
    "@demoforge/capture": "workspace:*",
    "@demoforge/storyboard": "workspace:*",
    "@demoforge/voice": "workspace:*",
    "@demoforge/render": "workspace:*",
    "@demoforge/integrations": "workspace:*",
    "archiver": "^7.0.1",
    "bullmq": "^5.13.2",
    "ioredis": "^5.4.1",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/node": "^22.5.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
