# ----------------------------------------------------------------------------
# DemoForge environment. Copy to .env and fill in. NEVER commit a real .env.
# ----------------------------------------------------------------------------

# Database (Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/demoforge"

# Queue (Redis)
REDIS_URL="redis://localhost:6379"

# App
APP_URL="http://localhost:3000"

# Auth.js
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# Object storage (S3-compatible; MinIO in dev)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="demoforge"
S3_ACCESS_KEY_ID="minio"
S3_SECRET_ACCESS_KEY="minio123"
S3_FORCE_PATH_STYLE="true"

# LLM provider abstraction: "anthropic" | "openai" | "none"
# With "none", storyboard/script fall back to deterministic builders (offline-safe).
LLM_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Higgsfield (OPTIONAL). If empty, b-roll/transition generation is skipped gracefully.
HIGGSFIELD_API_KEY=""
HIGGSFIELD_API_BASE_URL=""

# TTS provider: "none" | "elevenlabs"
# With "none", voice runs in script_only mode unless a human file is uploaded.
TTS_PROVIDER="none"
ELEVENLABS_API_KEY=""

# Local secret vault encryption key (dev). MUST be 32 bytes for AES-256-GCM.
# Generate: openssl rand -base64 32
LOCAL_SECRET_ENCRYPTION_KEY="replace-with-32-byte-key"

# Capture (Playwright)
PLAYWRIGHT_HEADLESS="true"
CAPTURE_DEFAULT_WIDTH="1440"
CAPTURE_DEFAULT_HEIGHT="900"

# Render (Remotion / FFmpeg)
RENDER_FPS="30"
RENDER_WIDTH="1920"
RENDER_HEIGHT="1080"
