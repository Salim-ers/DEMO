# ----------------------------------------------------------------------------
# Studio One environment. Copy to .env and fill in. NEVER commit a real .env.
# ----------------------------------------------------------------------------

# Database (Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/studio-one"

# Queue (Redis)
REDIS_URL="redis://localhost:6379"

# App
APP_URL="http://localhost:3000"

# Auth.js
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"

# Object storage (S3-compatible; MinIO in dev)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="studio-one"
S3_ACCESS_KEY_ID="minio"
S3_SECRET_ACCESS_KEY="minio123"
S3_FORCE_PATH_STYLE="true"

# LLM provider abstraction: "anthropic" | "openai" | "none"
# With "none", storyboard/script fall back to deterministic builders (offline-safe).
LLM_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Higgsfield (OPTIONAL). If empty, b-roll/transition generation is skipped gracefully.
HIGGSFIELD_API_KEY=""
HIGGSFIELD_API_BASE_URL=""

# ----------------------------------------------------------------------------
# Video engine mode. "mock" (default) makes the whole UI work without any video
# keys: the production pipeline returns realistic statuses. "production" routes
# to the real Higgsfield / ElevenLabs / Remotion services in the worker.
# This one is public (read in the browser) so it must be NEXT_PUBLIC_.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_VIDEO_ENGINE_MODE="mock"

# Remotion final-assembly render endpoint (OPTIONAL, only in production mode).
# When empty, render falls back to the local packages/render pipeline.
REMOTION_RENDER_ENDPOINT=""

# Voice. Premium commercial demos default to a written script for studio/human
# recording. Modes: script_only | uploaded_human_voice | tts_provider.
VOICE_MODE="script_only"
# TTS provider (only used when a project's voice mode is tts_provider):
#   "none"       → no synthesis (premium default — record a human voice instead)
#   "elevenlabs" → premium neural voice (needs ELEVENLABS_API_KEY)
#   "google"     → free fallback voice (clear, but not studio grade)
TTS_PROVIDER="none"
ELEVENLABS_API_KEY=""
# Optional: a specific ElevenLabs voice id for natural French narration.
ELEVENLABS_VOICE_ID=""

# Local secret vault encryption key (dev). MUST be 32 bytes for AES-256-GCM.
# Generate: openssl rand -base64 32
LOCAL_SECRET_ENCRYPTION_KEY="replace-with-32-byte-key"

# Capture (Playwright) — crisp, pixel-sharp screenshots.
PLAYWRIGHT_HEADLESS="true"
CAPTURE_WIDTH="1920"
CAPTURE_HEIGHT="1080"
CAPTURE_DEVICE_SCALE_FACTOR="2"   # 2 = retina; 3 for 4K-downscale masters
CAPTURE_FORMAT="png"              # lossless; never recompressed before render
CAPTURE_QUALITY="lossless"

# Render (Remotion / FFmpeg) — premium master by default.
RENDER_FPS="30"
RENDER_WIDTH="1920"
RENDER_HEIGHT="1080"
RENDER_QUALITY="premium"          # premium | standard
RENDER_CRF="16"                   # 15–18 = visually-lossless screen content
RENDER_X264_PRESET="medium"       # medium | slow (better compression)
RENDER_VIDEO_BITRATE="12M"        # advisory target (1080p); 35M for 4K
RENDER_AUDIO_BITRATE="192k"       # 192k–256k
RENDER_AUDIO_SAMPLE_RATE="48000"
RENDER_RESOLUTION="1080p"         # 1080p | 1440p | 4k
RENDER_ENABLE_4K="false"

# Background music & sound design (optional, Phase 3).
# Path/URL to a royalty-free corporate music bed; ducked under the voice.
RENDER_MUSIC_URL=""
RENDER_MUSIC_GAIN_DB="-28"        # bed loudness target under narration
